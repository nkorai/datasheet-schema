{
  "schemaVersion": "1.0",
  "component": {
    "mpn": "LM5116MH",
    "manufacturer": "Texas Instruments",
    "family": "dc_dc",
    "description": "Wide-range (6 to 100 V) synchronous buck controller with emulated peak current-mode control. Drives external high-side and low-side N-channel MOSFETs; populates the gate-driver, current-sense-threshold, internal-bias-regulator, and voltage-mode error-amplifier keys rather than integrated-FET on-resistance.",
    "polarity": "positive",
    "package": "HTSSOP-20",
    "pinCount": 20,
    "lifecycle": "active",
    "temperatureGrade": "-40..125",
    "orderingVariants": [
      {
        "orderCode": "LM5116MH/NOPB",
        "package": "HTSSOP-20 (PWP)",
        "packing": "Tube"
      },
      {
        "orderCode": "LM5116MHX/NOPB",
        "package": "HTSSOP-20 (PWP)",
        "packing": "Tape and Reel"
      }
    ]
  },
  "pinout": [
    { "number": 1, "name": "VIN", "function": "IN", "type": "power", "description": "Chip supply, input-voltage monitor, and input to the VCC regulator.", "sourcePage": 3 },
    { "number": 2, "name": "UVLO", "function": "UVLO", "type": "analog", "description": "Programmable line undervoltage-lockout input; 5 uA pull-up when EN is high.", "sourcePage": 4 },
    { "number": 3, "name": "RT/SYNC", "function": "RT", "type": "analog", "description": "Oscillator timing resistor to AGND (50 kHz to 1 MHz); accepts an external sync clock.", "sourcePage": 3 },
    { "number": 4, "name": "EN", "function": "EN", "type": "digital_in", "description": "Enable. Below 0.5 V the part draws < 10 uA; pull above 3.3 V for normal operation.", "sourcePage": 3 },
    { "number": 5, "name": "RAMP", "function": "RAMP", "type": "analog", "description": "Emulated-ramp capacitor to AGND; sets the current-mode ramp slope.", "sourcePage": 3 },
    { "number": 6, "name": "AGND", "function": "GND", "type": "power", "description": "Analog ground; tie to PGND through the exposed pad.", "sourcePage": 3 },
    { "number": 7, "name": "SS", "function": "SS", "type": "analog", "description": "Soft-start capacitor charged by an internal 10 uA source.", "sourcePage": 3 },
    { "number": 8, "name": "FB", "function": "FB", "type": "analog", "description": "Feedback to the error-amp inverting input; regulates to 1.215 V.", "sourcePage": 3 },
    { "number": 9, "name": "COMP", "function": "COMP", "type": "analog", "description": "Error-amplifier output; loop compensation network to FB.", "sourcePage": 3 },
    { "number": 10, "name": "VOUT", "function": "SENSE", "type": "analog", "description": "Output-voltage monitor for the emulated ramp; connect directly to the regulated output.", "sourcePage": 3 },
    { "number": 11, "name": "DEMB", "function": "DEMB", "type": "analog", "description": "Diode-emulation / low-side source monitor.", "sourcePage": 3 },
    { "number": 12, "name": "CS", "function": "CS", "type": "analog", "description": "Current-sense amplifier positive input (top of Rsense or LS-FET drain).", "sourcePage": 3 },
    { "number": 13, "name": "CSG", "function": "CSG", "type": "analog", "description": "Current-sense amplifier ground input (bottom of Rsense or LS-FET source).", "sourcePage": 3 },
    { "number": 14, "name": "PGND", "function": "GND", "type": "power", "description": "Power ground; tie to AGND through the exposed pad.", "sourcePage": 3 },
    { "number": 15, "name": "LO", "function": "LO", "type": "digital_out", "description": "Low-side MOSFET gate drive.", "sourcePage": 3 },
    { "number": 16, "name": "VCC", "function": "VCC", "type": "power", "description": "Internal bias/gate-drive regulator output; decouple locally to PGND.", "sourcePage": 4 },
    { "number": 17, "name": "VCCX", "function": "VCCX", "type": "power", "description": "Optional external VCC supply; above 4.5 V it takes over from the internal regulator.", "sourcePage": 4 },
    { "number": 18, "name": "HB", "function": "HB", "type": "power", "description": "High-side bootstrap gate-drive supply.", "sourcePage": 3 },
    { "number": 19, "name": "HO", "function": "HO", "type": "digital_out", "description": "High-side MOSFET gate drive.", "sourcePage": 3 },
    { "number": 20, "name": "SW", "function": "SW", "type": "analog", "description": "Switch node; bootstrap capacitor negative terminal and HS-FET source.", "sourcePage": 3 },
    { "number": 21, "name": "EP", "function": "PAD", "type": "thermal", "description": "Exposed die-attach pad; solder to the ground plane.", "sourcePage": 4 }
  ],
