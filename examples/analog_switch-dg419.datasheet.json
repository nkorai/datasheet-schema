{
  "schemaVersion": "1.0",
  "component": {
    "mpn": "DG419",
    "manufacturer": "Vishay Siliconix",
    "family": "analog_switch",
    "description": "Precision CMOS SPDT (single-pole double-throw) analog switch (sub_type: switch, config: SPDT). One common terminal (D) selects between two throws (S1, S2) under a single logic-control input (IN). +/-15 V analog signal range, on-resistance 20 ohm typ, 5 pC charge injection, and guaranteed break-before-make so the two throws never momentarily short. Operates from dual supplies (+/-5 V to +/-20 V) or a single supply (+5 V to +40 V, 44 V max), with a separate logic-supply pin (VL) that makes the digital control TTL- and CMOS-compatible independent of the analog rails. Built on Vishay Siliconix's high-voltage silicon-gate (HVSG) process; each channel conducts equally in both directions when on and blocks to the supply rail when off. DG419 is the SPDT member of the DG417/DG418/DG419 family (DG417/DG418 are SPST).",
    "package": "SOIC-8",
    "pinCount": 8,
    "polarity": "positive",
    "lifecycle": "active",
    "temperatureGrade": "-40..85",
    "orderingVariants": [
      { "orderCode": "DG419DY", "package": "SOIC-8 (narrow)", "packing": "Tube" },
      { "orderCode": "DG419DY-E3", "package": "SOIC-8 (narrow)", "packing": "Tube, RoHS" },
      { "orderCode": "DG419DY-T1", "package": "SOIC-8 (narrow)", "packing": "Tape and Reel" },
      { "orderCode": "DG419DY-T1-E3", "package": "SOIC-8 (narrow)", "packing": "Tape and Reel, RoHS" },
      { "orderCode": "DG419DJ", "package": "MiniDIP-8", "packing": "Tube" }
    ]
  },
  "pinout": [
    { "number": 1, "name": "D", "function": "D", "type": "analog", "description": "Common (pole) terminal; connects to the selected throw when its switch is on. Bidirectional analog signal path.", "sourcePage": 1 },
    { "number": 2, "name": "S1", "function": "S1", "type": "analog", "description": "Throw-1 source terminal. On (connected to D) when logic input IN = 0.", "sourcePage": 1 },
    { "number": 3, "name": "GND", "function": "GND", "type": "power", "description": "Ground / logic reference.", "sourcePage": 1 },
    { "number": 4, "name": "V+", "function": "VP", "type": "power", "description": "Positive analog supply rail (e.g. +15 V dual, or +12 V single).", "sourcePage": 1 },
    { "number": 5, "name": "VL", "function": "VL", "type": "power", "description": "Separate logic supply (e.g. +5 V); sets the TTL/CMOS-compatible input threshold independent of the analog rails.", "sourcePage": 1 },
    { "number": 6, "name": "IN", "function": "IN", "type": "digital_in", "description": "Logic control input. IN = 0 turns SW1 on (D-S1), IN = 1 turns SW2 on (D-S2). TTL/CMOS compatible.", "sourcePage": 1 },
    { "number": 7, "name": "V-", "function": "VN", "type": "power", "description": "Negative analog supply rail (e.g. -15 V dual, or 0 V single-supply).", "sourcePage": 1 },
    { "number": 8, "name": "S2", "function": "S2", "type": "analog", "description": "Throw-2 source terminal. On (connected to D) when logic input IN = 1.", "sourcePage": 1 }
  ],
