  "component": {
    "mpn": "TIP120",
    "manufacturer": "onsemi",
    "family": "bjt",
    "description": "NPN epitaxial Darlington transistor (sub_type: darlington), 60 V, 5 A, medium-power linear and switching applications. Monolithic two-stage Darlington with integrated base-emitter bias resistors R1 (~8 kohm, input stage) and R2 (~0.12 kohm, output stage), giving a very high hFE (>=1000) at the cost of an elevated VCE(sat) and a stacked-junction VBE(on) of ~2.5 V. TIP120/121/122 differ only in breakdown voltage (60/80/100 V); this document describes the TIP120 grade.",
    "package": "TO-220",
    "pinCount": 3,
    "polarity": "positive",
    "lifecycle": "active",
    "temperatureGrade": "-65..150",
    "orderingVariants": [
      {
        "orderCode": "TIP120",
        "package": "TO-220 3L (Single Gauge)",
        "packing": "Bulk"
      },
      {
        "orderCode": "TIP120TU",
        "package": "TO-220 3L (Single Gauge)",
        "packing": "Rail"
      }
    ]
  },
