{
  "schemaVersion": "1.0",
  "component": {
    "mpn": "LT3094",
    "manufacturer": "Analog Devices",
    "family": "ldo",
    "polarity": "negative",
    "description": "–20 V, 500 mA, ultralow-noise, ultrahigh-PSRR negative linear regulator with a current-reference (100 uA SET-pin) architecture. Output programmed by a single resistor, VSET = ISET x RSET, over a 0 V to –19.5 V range.",
    "package": "12-Lead MSOP (MSE) / 3mm x 3mm DFN (DD)",
    "pinCount": 12,
    "lifecycle": "active",
    "temperatureGrade": "-40..125",
    "orderingVariants": [
      { "orderCode": "LT3094EDD#TRPBF", "package": "12-Lead (3mm x 3mm) DFN", "temperatureGrade": "-40..125", "packing": "Tape and Reel" },
      { "orderCode": "LT3094IDD#TRPBF", "package": "12-Lead (3mm x 3mm) DFN", "temperatureGrade": "-40..125", "packing": "Tape and Reel" },
      { "orderCode": "LT3094EMSE#TRPBF", "package": "12-Lead MSOP", "temperatureGrade": "-40..125", "packing": "Tape and Reel" },
      { "orderCode": "LT3094IMSE#TRPBF", "package": "12-Lead MSOP", "temperatureGrade": "-40..125", "packing": "Tape and Reel" }
    ]
  },
  "pinout": [
    { "number": 1, "name": "IN", "function": "IN", "type": "power", "description": "Input supply (negative rail). Exposed pad (pin 13) is also IN.", "sourcePage": 15 },
    { "number": 2, "name": "IN", "function": "IN", "type": "power", "sourcePage": 15 },
    { "number": 3, "name": "EN/UV", "function": "EN", "type": "digital_in", "description": "Bidirectional enable / UVLO. Turns on above +1.26 V or below –1.26 V relative to GND. Tie to IN if unused.", "sourcePage": 15 },
    { "number": 4, "name": "PG", "function": "PG", "type": "digital_out", "description": "Open-collector power-good flag. Pulls low when PGFB is between 0 V and –300 mV.", "sourcePage": 15 },
    { "number": 5, "name": "PGFB", "function": "PGFB", "type": "analog", "description": "Power-good feedback and fast-start-up input. Divider between OUT, PGFB and GND sets the PG threshold.", "sourcePage": 15 },
    { "number": 6, "name": "ILIM", "function": "ILIM", "type": "analog", "description": "Current-limit programming pin. Resistor to GND sets the limit at a nominal 3.75 A*kohm scale factor.", "sourcePage": 15 },
    { "number": 7, "name": "VIOC", "function": "VIOC", "type": "analog", "description": "Voltage for input-to-output control. Tracks an upstream supply to hold the LT3094 differential constant.", "sourcePage": 15 },
    { "number": 8, "name": "SET", "function": "ADJ", "type": "analog", "description": "Inverting error-amp input and regulation setpoint. Sinks a precise 100 uA; external RSET from SET to GND sets VOUT = ISET x RSET. A SET-to-GND cap (CSET) lowers noise and improves PSRR.", "sourcePage": 15 },
    { "number": 9, "name": "GND", "function": "GND", "type": "power", "sourcePage": 15 },
    { "number": 10, "name": "OUTS", "function": "SENSE", "type": "analog", "description": "Output sense; noninverting error-amp input. Kelvin-connect to the output capacitor and load.", "sourcePage": 15 },
    { "number": 11, "name": "OUT", "function": "OUT", "type": "power", "sourcePage": 15 },
    { "number": 12, "name": "OUT", "function": "OUT", "type": "power", "sourcePage": 15 }
