{
  "schemaVersion": "1.0",
  "component": {
    "mpn": "LT3748",
    "manufacturer": "Analog Devices",
    "family": "dc_dc",
    "description": "Isolated, no-opto, primary-side-sensing boundary-mode flyback controller. The part has NO VOUT pin and NO feedback divider: the output voltage is inferred from the primary-side flyback pulse sampled on the RFB pin, set by the RFB/RREF resistor ratio times the transformer primary-to-secondary turns ratio. Drives an external N-channel power MOSFET; populates the flyback-feedback keys (tc_current, flyback_comparator_trip_current) and the boundary/critical-conduction-mode timers (max_on_time, max_off_time, max_discontinuous_off_time) rather than any VOUT-divider reference.",
    "polarity": "positive",
    "package": "MSOP-16(12)",
    "pinCount": 16,
    "lifecycle": "active",
    "temperatureGrade": "-40..150",
    "orderingVariants": [
      { "orderCode": "LT3748EMS#PBF", "package": "MSOP-16(12) (MS16)", "temperatureGrade": "-40..125", "packing": "Tube" },
      { "orderCode": "LT3748EMS#TRPBF", "package": "MSOP-16(12) (MS16)", "temperatureGrade": "-40..125", "packing": "Tape and Reel" },
      { "orderCode": "LT3748IMS#PBF", "package": "MSOP-16(12) (MS16)", "temperatureGrade": "-40..125", "packing": "Tube" },
      { "orderCode": "LT3748IMS#TRPBF", "package": "MSOP-16(12) (MS16)", "temperatureGrade": "-40..125", "packing": "Tape and Reel" },
      { "orderCode": "LT3748HMS#PBF", "package": "MSOP-16(12) (MS16)", "temperatureGrade": "-40..150", "packing": "Tube" },
      { "orderCode": "LT3748HMS#TRPBF", "package": "MSOP-16(12) (MS16)", "temperatureGrade": "-40..150", "packing": "Tape and Reel" },
      { "orderCode": "LT3748MPMS#PBF", "package": "MSOP-16(12) (MS16)", "temperatureGrade": "-55..150", "packing": "Tube" },
      { "orderCode": "LT3748MPMS#TRPBF", "package": "MSOP-16(12) (MS16)", "temperatureGrade": "-55..150", "packing": "Tape and Reel" }
    ]
  },
  "pinout": [
    { "number": 1, "name": "VIN", "function": "IN", "type": "power", "description": "Chip supply and input to the INTVCC regulator. Operating range 5 V to 100 V.", "sourcePage": 8 },
    { "number": 3, "name": "EN/UVLO", "function": "EN", "type": "analog", "description": "Combined enable and precision undervoltage-lockout input; 1.223 V rising threshold with a switched hysteresis current. Below the falling threshold the part shuts down.", "sourcePage": 8 },
    { "number": 5, "name": "INTVCC", "function": "VCC", "type": "power", "description": "Internal 7 V bias/gate-drive regulator output; may be overdriven by a third transformer winding (4.5 V to 20 V) for efficiency. Decouple locally.", "sourcePage": 8 },
    { "number": 6, "name": "GATE", "function": "GATE", "type": "digital_out", "description": "Gate drive for the external N-channel power MOSFET, swinging between GND and INTVCC.", "sourcePage": 8 },
    { "number": 7, "name": "SENSE", "function": "SENSE", "type": "analog", "description": "Current-sense input across the external source-sense resistor; sets the peak switch current cycle by cycle.", "sourcePage": 8 },
    { "number": 8, "name": "GND", "function": "GND", "type": "power", "description": "Device ground.", "sourcePage": 8 },
    { "number": 9, "name": "GND", "function": "GND", "type": "power", "description": "Device ground.", "sourcePage": 8 },
    { "number": 10, "name": "SS", "function": "SS", "type": "analog", "description": "Soft-start capacitor charged by an internal source; a fault resets it.", "sourcePage": 8 },
    { "number": 11, "name": "VC", "function": "COMP", "type": "analog", "description": "Error-amplifier output and loop-compensation node; its voltage sets the current-sense threshold cycle by cycle.", "sourcePage": 8 },
    { "number": 12, "name": "TC", "function": "TC", "type": "analog", "description": "Temperature-compensation pin. An external RTC resistor sets a current (ITC = 0.55 V / RTC) into the RREF node to cancel the output rectifier's forward-voltage temperature drift.", "sourcePage": 8 },
    { "number": 14, "name": "RREF", "function": "RREF", "type": "analog", "description": "Bandgap-referenced pin; the external RREF resistor sets the reference current for the primary-side output-voltage sensing.", "sourcePage": 8 },
    { "number": 16, "name": "RFB", "function": "RFB", "type": "analog", "description": "Primary-flyback-feedback pin. The external RFB resistor samples the primary flyback voltage; with RREF and the transformer turns ratio it sets the regulated output. This is NOT a VOUT divider tap - the part has no VOUT pin.", "sourcePage": 8 }
  ],
