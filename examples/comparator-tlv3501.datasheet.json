{
  "schemaVersion": "1.0",
  "component": {
    "mpn": "TLV3501",
    "manufacturer": "Texas Instruments",
    "family": "comparator",
    "description": "4.5-ns, rail-to-rail I/O, high-speed single comparator with a push-pull CMOS output stage, an active-low shutdown pin, and 6 mV of internal input hysteresis. Beyond-the-rails input common-mode range; the rail-to-rail output directly drives CMOS or TTL. sub_type: high_speed. output stage: push_pull.",
    "package": "SOT-23-6",
    "pinCount": 6,
    "polarity": "positive",
    "lifecycle": "active",
    "temperatureGrade": "-40..125",
    "orderingVariants": [
      { "orderCode": "TLV3501AIDBVR", "package": "SOT-23-6 (DBV)", "packing": "Tape and Reel" },
      { "orderCode": "TLV3501AIDBVT", "package": "SOT-23-6 (DBV)", "packing": "Tape and Reel" }
    ]
  },
  "pinout": [
    { "number": 1, "name": "-IN", "function": "IN_N", "type": "analog", "description": "Negative (inverting) input.", "sourcePage": 3 },
    { "number": 2, "name": "V-", "function": "VS_NEG", "type": "power", "description": "Negative (lowest) power supply.", "sourcePage": 3 },
    { "number": 3, "name": "+IN", "function": "IN_P", "type": "analog", "description": "Positive (noninverting) input.", "sourcePage": 3 },
    { "number": 4, "name": "V+", "function": "VS_POS", "type": "power", "description": "Positive (highest) power supply.", "sourcePage": 3 },
    { "number": 5, "name": "OUT", "function": "OUT", "type": "digital_out", "description": "Push-pull comparator output.", "sourcePage": 3 },
    { "number": 6, "name": "SHDN", "function": "SHDN", "type": "digital_in", "description": "Shutdown. Device is enabled when SHDN is more than 1.7 V below V+, disabled when within 0.9 V of V+.", "sourcePage": 3 }
