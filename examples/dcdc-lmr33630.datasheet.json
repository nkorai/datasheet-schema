{
  "schemaVersion": "1.0",
  "component": {
    "mpn": "LMR33630",
    "manufacturer": "Texas Instruments",
    "family": "dc_dc",
    "description": "SIMPLE SWITCHER 3.8-V to 36-V, 3-A synchronous step-down (buck) converter with integrated high-side and low-side power MOSFETs, peak-current-mode control, precision enable, and power-good flag. Adjustable output 1 V to 24 V. Available in 400-kHz (A), 1.4-MHz (B), and 2.1-MHz (C) frequency options and in HSOIC-8 (DDA) and VQFN-12 (RNX) packages.",
    "package": "HSOIC (DDA-8) / VQFN (RNX-12)",
    "pinCount": 8,
    "polarity": "positive",
    "lifecycle": "active",
    "temperatureGrade": "-40..125",
    "orderingVariants": [
      { "orderCode": "LMR33630ADDA", "package": "HSOIC (DDA-8)", "packing": "Tube / Tape and Reel" },
      { "orderCode": "LMR33630BDDA", "package": "HSOIC (DDA-8)", "packing": "Tube / Tape and Reel" },
      { "orderCode": "LMR33630CDDA", "package": "HSOIC (DDA-8)", "packing": "Tube / Tape and Reel" },
      { "orderCode": "LMR33630ARNX", "package": "VQFN (RNX-12)", "packing": "Tape and Reel" },
      { "orderCode": "LMR33630BRNX", "package": "VQFN (RNX-12)", "packing": "Tape and Reel" },
      { "orderCode": "LMR33630CRNX", "package": "VQFN (RNX-12)", "packing": "Tape and Reel" }
    ]
  },
  "pinout": [
    { "number": 1, "name": "PGND", "function": "PGND", "type": "power", "description": "Power ground terminal.", "sourcePage": 5 },
    { "number": 2, "name": "VIN", "function": "IN", "type": "power", "description": "Input supply to regulator.", "sourcePage": 5 },
    { "number": 3, "name": "EN", "function": "EN", "type": "digital_in", "description": "Precision enable input. High = ON, low = OFF. Do not float.", "sourcePage": 5 },
    { "number": 4, "name": "PG", "function": "PG", "type": "digital_out", "description": "Open-drain power-good flag output.", "sourcePage": 5 },
    { "number": 5, "name": "FB", "function": "FB", "type": "analog", "description": "Feedback input; connect to the feedback divider tap.", "sourcePage": 5 },
    { "number": 6, "name": "VCC", "function": "VCC", "type": "power", "description": "Internal 5-V LDO output; supply to internal control circuits. Bypass 1 uF to GND.", "sourcePage": 5 },
